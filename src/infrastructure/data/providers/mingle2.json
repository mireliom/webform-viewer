{
  "service_url": "https://mingle2.com/welcome/contact_us",
  "pages": [
    {
      "fields": [
        {
          "field_name": "full_name",
          "field_type": "type",
          "field_selector": "#contact_us_name",
          "field_default_value": null
        },
        {
          "field_name": "reply_to",
          "field_type": "type",
          "field_selector": "#contact_us_email_address",
          "field_default_value": null
        },
        {
          "field_name": "reason",
          "field_type": "select",
          "field_selector": "#contact_us_reason",
          "field_default_value": "opt_out"
        },
        {
          "field_name": "subject",
          "field_type": "type",
          "field_selector": "#contact_us_subject",
          "field_default_value": "Cancel Subscription"
        },
        {
          "field_name": "message",
          "field_type": "message",
          "field_selector": "#contact_us_body",
          "field_default_value": ""
        },
        {
          "field_name": "captcha",
          "field_type": "2captcha",
          "field_selector": ""
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_name": "submit",
          "field_type": "click",
          "field_selector": "input[type='submit'][value='Submit']"
        }
      ]
    }
  ],
  "validation": {
    "selector": "div.responsive-height.container.py-5.body-content.text-center",
    "value": "Your message has been successfully submitted",
    "name_suffix": "confirmation"
  }
}
{
  "service_url": "https://foodstirs.com/pages/contact-us",
  "pages": [
    {
      "fields": [
        {
          "field_name": "full_name",
          "field_type": "type",
          "field_selector": "#ContactFormName",
          "field_default_value": ""
        },
        {
          "field_name": "reply_to",
          "field_type": "type",
          "field_selector": "#ContactFormEmail",
          "field_default_value": ""
        },
        {
          "field_name": "contact_phone",
          "field_type": "type",
          "field_selector": "#ContactFormPhone",
          "field_default_value": ""
        },
        {
          "field_name": "message",
          "field_type": "message",
          "field_selector": "#ContactFormMessage",
          "field_default_value": ""
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_name": "submit",
          "field_type": "click",
          "field_selector": "#contact_form > input[type=submit]"
        }
      ],
      "closeable": [
        {
          "field_type": "click",
          "field_selector": "#contact-us > div:nth-child(50) > div > div > div > div > div > div > button > svg > path"
        }
      ]
    }
  ],
  "validation": {
    "selector": "p[class='note form-success']",
    "value": "Thanks for contacting us. We'll get back to you as soon as possible.",
    "name_suffix": "confirmation"
  }
}
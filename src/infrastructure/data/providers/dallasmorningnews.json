{
  "service_url": "https://dallasnews.zendesk.com/hc/en-us/requests/new?ticket_form_id=360000722711",
  "pages": [
    {
      "fields": [
        {
          "field_name": "reply_to",
          "field_type": "type",
          "field_selector": "#request_anonymous_requester_email",
          "field_default_value": null
        },
        {
          "field_name": "address",
          "field_type": "type",
          "field_selector": "#request_custom_fields_360030097532",
          "field_default_value": null
        },
        {
          "field_name": "contact_phone",
          "field_type": "type",
          "field_selector": "form > div:nth-child(5) > input",
          "field_default_value": null,
          "field_format": "phone"
        },
        {
          "field_name": "reason",
          "field_type": "evaluate",
          "field_selector": "#request_custom_fields_360027651552",
          "field_default_value": "cancel_print"
        },
        {
          "field_name": "subject",
          "field_type": "type",
          "field_selector": "#request_subject",
          "field_default_value": "Cancel my subscription"
        },
        {
          "field_name": "message",
          "field_type": "message",
          "field_selector": "#request_description",
          "field_default_value": ""
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_name": "submit",
          "field_type": "click",
          "field_selector": "footer > input[type='submit'][name='commit']"
        }
      ]
    }
  ],
  "validation": {
    "selector": "header > div:nth-child(2)",
    "value": "Your request was successfully submitted.",
    "name_suffix": "confirmation"
  }
}
{
  "service_url": "https://www.bigpondassociation.com/home/about-us",
  "pages": [
    {
      "fields": [
        {
          "field_name": "timer",
          "field_type": "wait",
          "time": 5000
        },
        {
          "field_type": "iframe",
          "child": {
            "field_name": "reply_to",
            "field_type": "type",
            "field_selector": "#fields.110",
            "field_default_value": null
          }
        },
        {
          "field_type": "iframe",
          "child": {
            "field_name": "subject",
            "field_type": "type",
            "field_selector": "#fields.114",
            "field_default_value": "Cancel Subscription"
          }
        },
        {
          "field_type": "iframe",
          "child": {
            "field_name": "message",
            "field_type": "message",
            "field_selector": "#fields.118",
            "field_default_value": "Please cancel the account and all associated recurring charges for the account under ${event.full_name} and email ${event.email} effective ${event.current_date}, if available make the account a free plan. Please advise me of the refunded amount that will be applied to the card on file. -Thank you!"
          }
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_type": "iframe",
          "child": {
            "field_name": "submit",
            "field_type": "click",
            "field_selector": "button[type='submit']"
          }
        }
      ]
    }
  ],
  "validation": {
    "selector": "div[data-test-id='notification']",
    "value": "Your request was successfully submitted.",
    "name_suffix": "confirmation"
  }
}

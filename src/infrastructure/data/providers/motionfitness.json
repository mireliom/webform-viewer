{
  "service_url": "https://motionfitness.com/contact/",
  "pages": [
    {
      "fields": [
        {
          "field_name": "full_name",
          "field_type": "type",
          "field_selector": "input[name='your-name']",
          "field_default_value": ""
        },
        {
          "field_name": "reply_to",
          "field_type": "type",
          "field_selector": "input[name='your-email']",
          "field_default_value": ""
        },
        {
          "field_name": "subject",
          "field_type": "type",
          "field_selector": "input[name='your-subject']",
          "field_default_value": "Cancel Subscription"
        },
        {
          "field_name": "message",
          "field_type": "message",
          "field_selector":"textarea[name='your-message']",
          "field_default_value": ""
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_name": "submit",
          "field_type": "click",
          "field_selector": "input[type='submit'][value='Submit your message']"
        }
      ]
    }
  ],
  "validation": {
    "selector": "span.fusion-alert-content",
    "value": "THANK YOU FOR YOUR MESSAGE",
    "name_suffix": "confirmation"
  }
}
{
  "service_url": "https://www.groupon.com/faq/email_us",
  "pages": [
    {
      "fields": [
        {
          "field_name": "reply_to",
          "field_type": "type",
          "field_selector": "input[name='emailAddress']"
        },
        {
          "field_name": "help",
          "field_type": "select",
          "field_selector": "select[name='needHelpWith']",
          "field_default_value": "account_issue"
        },
        {
          "field_name": "issue",
          "field_type": "select",
          "field_selector": "select[name='bestDescribesYourIssue']",
          "field_default_value": "something_else"
        },
        {
          "field_name": "message",
          "field_type": "message",
          "field_selector": "textarea[name='issueDescription']",
          "field_default_value": ""
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_name": "submit",
          "field_type": "click",
          "field_selector": "div.actions > button"
        },
        {
          "field_name": "timer",
          "field_type": "wait",
          "time": 2000
        }
      ]
    }
  ],
  "validation": {
    "selector": "#emailUs-app > div > h2",
    "value": "Thank You",
    "name_suffix": "confirmation"
  }
}
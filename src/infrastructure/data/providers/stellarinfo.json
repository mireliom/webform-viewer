{
  "service_url": "https://www.stellarinfo.com/contact/contact-us.php",
  "pages": [
    {
      "fields": [
        {
          "field_name": "full_name",
          "field_type": "type",
          "field_selector": "#name",
          "field_default_value": ""
        },
        {
          "field_name": "reply_to",
          "field_type": "type",
          "field_selector": "input[name='email'][placeholder='Email*']",
          "field_default_value": ""
        },
        {
          "field_name": "contact_phone",
          "field_type": "type",
          "field_selector": "#contact_number",
          "field_default_value": ""
        },
        {
          "field_name": "country",
          "field_type": "select",
          "field_selector": "#country",
          "field_default_value": "United States"
        },
        {
          "field_name": "message",
          "field_type": "message",
          "field_selector": "#details",
          "field_default_value": ""
        },
        {
          "field_name": "captcha",
          "field_type": "img_captcha",
          "src_selector": "li.calc_captcha",
          "field_selector": "#captchval_busi"
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_name": "submit",
          "field_type": "click",
          "field_selector": "input[type='submit'][value='Submit']",
          "field_default_value": null
        }
      ]
    }
  ],
  "validation": {
    "selector": "#show_success_message",
    "value": "Thank you! Your form was successfully submitted.",
    "name_suffix": "confirmation"
  }
}
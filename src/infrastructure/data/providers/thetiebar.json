{
  "service_url": "https://thetiebar.zendesk.com/hc/en-us/requests/new",
  "biller_id": "pro_15886109105637534fdkfKTpYQRs",
  "proxy": true,
  "pages": [
    {
      "fields": [
        {
          "field_name": "reply_to",
          "field_type": "type",
          "field_selector": "#request_anonymous_requester_email",
          "field_default_value": null
        },
        {
          "field_name": "subject",
          "field_type": "type",
          "field_selector": "#request_subject",
          "field_default_value": "Cancel Subscription"
        },
        {
          "field_name": "message",
          "field_type": "message",
          "field_selector": "#request_description",
          "field_default_value": ""
        },
        {
          "field_type": "screenshot",
          "name_suffix": "data"
        },
        {
          "field_name": "submit",
          "field_type": "click",
          "field_selector": "footer > input[type='submit'][name='commit']"
        },
        {
          "field_name": "timer",
          "field_type": "wait",
          "time": 2000
        }
      ]
    }
  ],
  "validation": {
    "selector": "strong",
    "value": "Your request was successfully submitted.",
    "name_suffix": "confirmation"
  }
}